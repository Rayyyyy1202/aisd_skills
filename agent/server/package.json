{
  "name": "aisd-agent-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env.local src/api/server.ts",
    "start": "tsx --env-file-if-exists=.env.local src/api/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "test:output": "node --test tests/output-endpoint.test.mjs"
  },
  "dependencies": {
    "@hono/node-server": "1.13.7",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "better-sqlite3": "11.7.0",
    "gray-matter": "4.0.3",
    "hono": "4.6.13",
    "openai": "4.76.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.12",
    "@types/node": "22.10.2",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
